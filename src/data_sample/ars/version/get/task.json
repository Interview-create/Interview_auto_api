      "description": "取得",
      "keep_payload_values": {
        "ars_amount_abc": "abc",
        "ars_amount_def_num": "def",
        "percent_num": "PLAN[0].MULTI_PROPORTION[0].PERCENT",
        "acc_json": "acc"
      },
      "payload": {
        "acc": "{\"account\": 123}",
        "ccc": "{{acc_json}}",
        "abc": 1,
        "def": 2,
        "PLAN": [
          {
            "MULTI_PROPORTION": [
              {
                "PERCENT": "100"
              }
            ]
          }
        ]
      }
    },
    "成功2": {
